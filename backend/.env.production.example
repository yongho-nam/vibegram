# 서버(PostgreSQL) — backend/.env 로 복사 후 값 수정
APP_ENV=production

# 한 줄로 지정 시 POSTGRES_* 보다 우선
# DATABASE_URL=postgresql+psycopg://instagram:CHANGE_ME@db:5432/instagram

POSTGRES_USER=instagram
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=instagram

JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
UPLOAD_DIR=./uploads
FRONTEND_ORIGIN=https://your-frontend.example
API_PUBLIC_BASE=https://api.your-frontend.example
EXPOSE_PASSWORD_RESET_LINK=false
