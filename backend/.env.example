# development(기본): SQLite  |  production: PostgreSQL (아래 POSTGRES_* 또는 DATABASE_URL)
APP_ENV=development

# 명시 시 APP_ENV보다 우선 (로컬에서 Postgres 쓸 때도 가능)
DATABASE_URL=sqlite:///./instagram.db

# APP_ENV=production 이고 DATABASE_URL 이 없을 때 조합됨
# POSTGRES_USER=instagram
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=instagram

# 서버 한 줄 예시:
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://instagram:secret@db:5432/instagram

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
UPLOAD_DIR=./uploads
FRONTEND_ORIGIN=http://localhost:5173
API_PUBLIC_BASE=http://localhost:8000
# true: 비밀번호 찾기 API가 JSON에 재설정 URL 포함(데모). 운영에서는 false 권장.
EXPOSE_PASSWORD_RESET_LINK=true
